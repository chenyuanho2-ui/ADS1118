@echo off
chcp 65001 >nul 2>&1
echo ==============================================
echo        一键取消所有文件只读属性工具
echo ==============================================
echo 本脚本将取消：
echo 1. 当前目录下所有文件的只读属性
echo 2. 所有子文件夹内文件的只读属性
echo.
echo ！！！操作不可逆，确认后将直接执行！！！
echo.
pause
echo.
echo 正在取消只读属性，请稍候...
echo.

:: 核心命令：取消当前目录及子目录所有文件的只读属性
attrib -r *.* /s /d >nul 2>&1

echo.
echo ==============================================
echo              操作完成！
echo 已取消当前目录及所有子目录文件的只读属性
echo ==============================================
pause
exit